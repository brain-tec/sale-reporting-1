<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <template
        id="report_saleorder_document_image"
        inherit_id="sale.report_saleorder_document"
    >
        <th name="th_description" position="before">
            <th name="th_image">Image</th>
        </th>
        <td name="td_name" position="before">
            <td name="td_image">
                <img
                    t-if="line.product_id.image_128"
                    t-att-src="image_data_uri(line.product_id.image_128)"
                    style="max-width: 64px;"
                    class="rounded"
                    alt="Product image"
                />
            </td>
        </td>
    </template>

</odoo>
